{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "InferenceForge",
  "uid": "inferenceforge",
  "tags": ["inferenceforge", "llm", "kubernetes"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [

    { "type": "row", "title": "Traffic", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "id": 100 },

    {
      "id": 1, "type": "stat", "title": "Requests / sec",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "reqps" } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(inferenceforge_requests_total[1m])", "legendFormat": "req/s" }]
    },

    {
      "id": 2, "type": "stat", "title": "Total Requests",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(inferenceforge_requests_total)", "legendFormat": "total" }]
    },

    {
      "id": 3, "type": "stat", "title": "Error Rate",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(inferenceforge_requests_total{status='error'}[5m]) / rate(inferenceforge_requests_total[5m])", "legendFormat": "error %" }]
    },

    {
      "id": 4, "type": "stat", "title": "Active Requests",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "inferenceforge_active_requests", "legendFormat": "active" }]
    },

    {
      "id": 5, "type": "stat", "title": "Queue Depth",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 80 }] } } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "inferenceforge_queue_depth", "legendFormat": "queued" }]
    },

    {
      "id": 6, "type": "stat", "title": "Tokens / sec",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] }, "unit": "short" } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(inferenceforge_tokens_total[1m])", "legendFormat": "tok/s" }]
    },

    { "type": "row", "title": "Latency", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "id": 101 },

    {
      "id": 10, "type": "timeseries", "title": "Request Latency — p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 6, "w": 14, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum(rate(inferenceforge_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p50" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum(rate(inferenceforge_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p95" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, sum(rate(inferenceforge_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p99" }
      ]
    },

    {
      "id": 11, "type": "timeseries", "title": "Latency Heatmap (avg by model)",
      "gridPos": { "x": 14, "y": 6, "w": 10, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(inferenceforge_request_duration_seconds_sum[2m]) / rate(inferenceforge_request_duration_seconds_count[2m])", "legendFormat": "avg {{model}}" }
      ]
    },

    { "type": "row", "title": "Throughput & Queue", "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }, "id": 102 },

    {
      "id": 20, "type": "timeseries", "title": "Requests / sec by Status",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(inferenceforge_requests_total[1m])", "legendFormat": "{{status}}" }
      ]
    },

    {
      "id": 21, "type": "timeseries", "title": "Token Throughput",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(inferenceforge_tokens_total[1m])", "legendFormat": "tokens/s — {{model}}" }
      ]
    },

    {
      "id": 22, "type": "timeseries", "title": "Queue Depth over Time",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 20 }, "color": { "fixedColor": "#FF9830", "mode": "fixed" } } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "inferenceforge_queue_depth", "legendFormat": "queue depth" }
      ]
    },

    { "type": "row", "title": "GPU (EKS)", "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }, "id": 103 },

    {
      "id": 30, "type": "timeseries", "title": "GPU Utilisation % (requires DCGM exporter)",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 15 }, "color": { "fixedColor": "#8AB8FF", "mode": "fixed" } } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU {{gpu}}" }
      ]
    },

    {
      "id": 31, "type": "timeseries", "title": "GPU Memory Used (GB)",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "decgbytes", "custom": { "lineWidth": 2, "fillOpacity": 15 }, "color": { "fixedColor": "#B877D9", "mode": "fixed" } } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "DCGM_FI_DEV_FB_USED / 1024", "legendFormat": "GPU {{gpu}} mem" }
      ]
    }
  ]
}
